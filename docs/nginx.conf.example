# earthborne.build — example nginx server block
#
# Place in:    /etc/nginx/sites-available/earthborne.build
# Enable with: ln -s /etc/nginx/sites-available/earthborne.build \
#                    /etc/nginx/sites-enabled/earthborne.build
# Reload with: nginx -t && systemctl reload nginx
#
# Adjust:
#   - server_name   → your domain
#   - root          → absolute path to frontend/dist on this machine
#   - proxy_pass    → backend port (default 8686, set via PORT in backend/.env)

server {
    listen 80;
    listen [::]:80;
    server_name earthborne.build;

    # Frontend — built static files
    root /srv/earthborne.build/frontend/dist;
    index index.html;

    # SPA routing: unknown paths fall back to index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Backend API proxy
    location ~ ^/(v2|version|admin|up)(/|$) {
        proxy_pass         http://127.0.0.1:8686;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # Compression
    gzip            on;
    gzip_vary       on;
    gzip_types      text/plain text/css application/json
                    application/javascript text/xml application/xml
                    text/javascript image/svg+xml;

    # Cache hashed assets forever; everything else is short-lived
    location ~* \.[0-9a-f]{8}\.(js|css|woff2?)$ {
        expires max;
        add_header Cache-Control "public, immutable";
    }
}
