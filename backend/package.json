{
  "name": "@arkham-build/backend",
  "main": "src/main.ts",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "check": "tsc",
    "dbmate": "dbmate",
    "db:up": "COMPOSE_MENU=0 docker compose up -d --build",
    "db:down": "docker compose down",
    "dev": "node --watch --experimental-strip-types --env-file=.env src/main.ts",
    "dev:inspect": "node --inspect=localhost:9229 --experimental-strip-types --env-file=.env src/main.ts",
    "generate:database-types": "kysely-codegen --out-file src/db/schema.types.ts",
    "ingest": "npm run ingest:metadata",
    "ingest:metadata": "node --experimental-strip-types --env-file-if-exists=.env --env-file-if-exists=../.env src/scripts/ingest-metadata.ts",
    "start": "node --experimental-strip-types src/main.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fast-csv/parse": "5.0.5",
    "@hono/node-server": "1.19.13",
    "hono": "4.12.12",
    "kysely": "0.28.14",
    "pg": "8.19.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "11.12.0",
    "@tsconfig/node-ts": "23.6.4",
    "@tsconfig/node24": "24.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@types/pg": "8.16.0",
    "dbmate": "2.31.0",
    "kysely-codegen": "0.20.0"
  }
}
