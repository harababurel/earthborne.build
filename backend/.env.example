# app
CORS_ORIGINS="http://localhost:3000"
NODE_ENV="development"
PORT="8686"

# database (SQLite)
SQLITE_PATH="./earthborne.db"

# migrations (dbmate)
DATABASE_URL="sqlite:./earthborne.db"
DBMATE_MIGRATIONS_DIR="src/db/migrations"
DBMATE_SCHEMA_FILE="src/db/schema.sql"

# card data ingestion
# Usage: CARD_DATA_DIR=/path/to/rangers-card-data npm run ingest:cards -w backend
CARD_DATA_DIR="/path/to/rangers-card-data"

# card image serving — directory downloaded by scripts/download-images.ts
# Structure: {IMAGE_DIR}/{pack_id}/{code}.jpg
# Usage: IMAGE_DIR=/path/to/earthborne.images/cards npm run download:images -w backend
IMAGE_DIR="/path/to/earthborne.images/cards"

# admin API key
ADMIN_API_KEY="change-me"
