# Base URL of the earthborne.build backend API.
# In production this is typically the same origin (empty string = relative URLs),
# or an absolute URL if the backend runs on a different host/port.
VITE_API_URL="http://localhost:8686"

# Legacy API base URL — currently used only for public share JSON links.
# Point to the same backend as VITE_API_URL.
VITE_API_LEGACY_URL="http://localhost:8686"

# Base URL of the card image host. Leave blank until a card image CDN is set up.
# Images will appear broken until this is configured.
# TODO: set to the ER card image host once available.
VITE_CARD_IMAGE_URL=""

# Name shown in the browser tab title.
VITE_PAGE_NAME="earthborne.build"

# Set to "true" to show the preview season banner.
VITE_SHOW_PREVIEW_BANNER="false"
